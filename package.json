{
  "name": "hermes-doctor-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local-first diagnostic CLI tool for Hermes Agent.",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "build": "tsc -b && pnpm --filter hermes-doctor build",
    "typecheck": "tsc -b",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint .",
    "dev": "tsx packages/cli/src/index.ts",
    "clean": "tsc -b --clean"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
